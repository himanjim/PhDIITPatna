# Ignore rules for the eVote UI demo repository.
# The list excludes rebuildable frontend artefacts, local operating-system clutter,
# performance run outputs, and captured still images used during bandwidth tests.
# The intention is to keep the repository small and to prevent accidental commit of
# temporary media or measurement files that do not belong in the audited source tree.

# dependencies
node_modules/

# build output (rebuildable)
dist/

# local temp / OS
.DS_Store
Thumbs.db

# perf raw run-by-run artefacts (bloat)
perf/ballot_*.json
perf/cast_*.json
perf/liveness_*.json
perf/start*.json

# face stills must never be committed
perf/stills/

# ad-hoc local lighthouse dumps at repo root
*.report.html

# temp binary outputs used during compression experiments
a+x.*
x.ext
